<Page x:ConnectionId='1'
    x:Class="WPGContacts.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                        >
    <!-- Добавили событие загрузки страницы -->

    <StackPanel Padding="20" VerticalAlignment="Center">
        <TextBlock Text="Google Контакты" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="by Computershik" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>

        <!-- Панель входа (показывается, если аккаунта нет) -->
        <!-- Панель входа (показывается, если аккаунта нет) -->
        <StackPanel x:ConnectionId='2' x:Name="LoginPanel" Visibility="Visible" Margin="0,20,0,0">
            <TextBlock Text="Настройки Google API:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:ConnectionId='9' x:Name="ClientIdBox" Header="Client ID" PlaceholderText="...apps.googleusercontent.com" Margin="0,0,0,10"/>
            <TextBox x:ConnectionId='10' x:Name="ClientSecretBox" Header="Client Secret" PlaceholderText="GOCSPX-..." Margin="0,0,0,15"/>

            <TextBlock Text="Подключите аккаунт для синхронизации:" Margin="0,0,0,10" />
            <Button x:ConnectionId='11' x:Name="LoginButton" Content="Авторизоваться"                           HorizontalAlignment="Stretch" Height="50" />
        </StackPanel>

        <!-- Панель с вводом кода (показывается в процессе входа) -->
        <StackPanel x:ConnectionId='3' x:Name="CodePanel" Visibility="Collapsed" Margin="0,15,0,0">
            <TextBlock Text="Введите этот код в браузере (скопирован в буфер):" TextWrapping="Wrap" />
            <TextBlock x:ConnectionId='8' x:Name="UserCodeText" Text="ABCD-1234" FontSize="32" FontWeight="Bold" Foreground="Orange" HorizontalAlignment="Center" Margin="0,10" />
            <ProgressRing IsActive="True" Width="40" Height="40" Margin="0,10" />
            <TextBlock Text="Ожидание подтверждения в браузере..." HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Панель успешного входа (показывается, если аккаунт уже привязан) -->
        <!-- Панель успешного входа (показывается, если аккаунт уже привязан) -->
        <StackPanel x:ConnectionId='4' x:Name="LoggedInPanel" Visibility="Collapsed" Margin="0,20,0,0">
            <TextBlock Text="Аккаунт успешно подключен!" FontWeight="SemiBold" Foreground="LightGreen" HorizontalAlignment="Center"/>
            <TextBlock Text="Контакты синхронизируются в фоновом режиме." TextWrapping="Wrap" Margin="0,5,0,20" HorizontalAlignment="Center" TextAlignment="Center"/>

            <!-- НОВАЯ КНОПКА РУЧНОЙ СИНХРОНИЗАЦИИ -->
            <Button x:ConnectionId='6' x:Name="ManualSyncButton" Content="Синхронизировать сейчас"                                HorizontalAlignment="Stretch" Margin="0,0,0,10" Background="#0078D7" Foreground="White"/>

            <Button x:ConnectionId='7' x:Name="LogoutButton" Content="Выйти из аккаунта"                            HorizontalAlignment="Stretch" />
        </StackPanel>

        <TextBlock x:ConnectionId='5' x:Name="StatusText" TextWrapping="Wrap" Foreground="LightGray" Margin="0,15,0,0" HorizontalAlignment="Center"/>
    </StackPanel>
</Page>

